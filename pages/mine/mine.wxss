.page {
  min-height: 100vh;
  background: #fcf8fb;
  color: #1b1b1d;
  overflow: hidden;
}

.nav-shell {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  background: rgba(252, 248, 251, 0.82);
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
}

.nav-left,
.nav-notify {
  position: absolute;
  width: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-left {
  left: 30rpx;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  width: 116rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  color: #904d00;
  font-size: 34rpx;
  line-height: 44rpx;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 700;
  text-align: center;
  letter-spacing: 0;
  text-shadow: none;
  transform: translateX(-50%);
}

.content {
  width: 100vw;
  height: 100vh;
  box-sizing: border-box;
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
}

.profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 26rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #e4e2e4;
  border-radius: 50%;
  background: #eae7ea;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.avatar-icon {
  width: 88rpx;
  height: 88rpx;
}

.profile-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 18rpx;
}

.profile-login-btn {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
}

.profile-login-btn::after {
  border: 0;
}

.login-title {
  color: #1b1b1d;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 600;
}

.login-subtitle {
  margin-top: 8rpx;
  color: rgba(86, 67, 52, 0.7);
  font-size: 25rpx;
  line-height: 35rpx;
  font-weight: 500;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 127rpx;
  padding: 30rpx 0;
  border: 1rpx solid rgba(221, 193, 174, 0.3);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1 1 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  color: #1b1b1d;
  font-size: 38rpx;
  line-height: 54rpx;
  font-weight: 600;
}

.stat-primary {
  color: #904d00;
}

.stat-label {
  color: #564334;
  font-size: 21rpx;
  line-height: 27rpx;
  font-weight: 600;
}

.stat-divider {
  width: 1rpx;
  height: 62rpx;
  background: rgba(221, 193, 174, 0.2);
}

.pro-card {
  position: relative;
  min-height: 142rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 46rpx;
  padding: 38rpx;
  overflow: hidden;
  border: 1rpx solid rgba(144, 77, 0, 0.1);
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(144, 77, 0, 0.055), rgba(144, 77, 0, 0.025));
  transition: transform 120ms ease;
}

.card-press,
.menu-press,
.tab-press {
  transform: scale(0.98);
}

.pro-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}

.pro-title {
  color: #904d00;
  font-size: 38rpx;
  line-height: 54rpx;
  font-weight: 600;
}

.pro-subtitle {
  margin-top: 2rpx;
  color: #6e3900;
  font-size: 25rpx;
  line-height: 35rpx;
  font-weight: 500;
}

.pro-icon {
  position: relative;
  z-index: 1;
  width: 58rpx;
  height: 58rpx;
}

.pro-glow {
  position: absolute;
  right: -31rpx;
  bottom: -31rpx;
  width: 154rpx;
  height: 154rpx;
  border-radius: 50%;
  background: rgba(144, 77, 0, 0.018);
}

.menu-card {
  margin-top: 26rpx;
  overflow: hidden;
  border: 1rpx solid rgba(221, 193, 174, 0.3);
  border-radius: 24rpx;
  background: #ffffff;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 106rpx;
  padding: 0 31rpx;
  box-sizing: border-box;
  transition: transform 120ms ease, background-color 120ms ease;
}

.menu-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  margin-right: 31rpx;
  border-radius: 50%;
  background: #f6f3f5;
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
}

.menu-title {
  color: #1b1b1d;
  font-size: 31rpx;
  line-height: 44rpx;
}

.chevron {
  width: 42rpx;
  height: 42rpx;
}

.menu-divider {
  height: 1rpx;
  margin: 0 31rpx;
  background: rgba(221, 193, 174, 0.12);
}

.version {
  padding: 31rpx 0;
  color: rgba(86, 67, 52, 0.3);
  font-size: 21rpx;
  line-height: 27rpx;
  font-weight: 600;
  text-align: center;
}

.bottom-spacer {
  height: 178rpx;
}

.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-around;
  min-height: 98rpx;
  padding: 5rpx 31rpx calc(5rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(221, 193, 174, 0.3);
  background: rgba(252, 248, 251, 0.82);
  -webkit-backdrop-filter: blur(24px);
  backdrop-filter: blur(24px);
}

.tab-item {
  min-width: 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #454749;
  font-size: 25rpx;
  line-height: 35rpx;
}

.tab-active {
  color: #904d00;
}

.tab-icon-img {
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 2rpx;
}
