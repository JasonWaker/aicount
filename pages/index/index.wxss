.page {
  min-height: 100vh;
  background: #fcf8fb;
  overflow: hidden;
}

.tap-target {
  min-width: 72rpx;
  min-height: 72rpx;
}

.nav-shell {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(252, 248, 251, 0.9);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
}

.nav-content {
  position: absolute;
  left: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  display: flex;
  align-items: center;
  min-width: 0;
  height: 100%;
}

.brand-icon {
  position: relative;
  width: 26rpx;
  height: 26rpx;
  flex: 0 0 auto;
  margin-right: 10rpx;
  border: 3rpx solid #904d00;
  border-radius: 6rpx;
}

.brand-icon::before {
  content: "";
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 7rpx;
  height: 3rpx;
  background: #904d00;
}

.brand-title {
  max-width: 220rpx;
  color: #904d00;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 40rpx;
  white-space: nowrap;
}

.content {
  width: 100vw;
  height: 100vh;
  box-sizing: border-box;
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-bottom: calc(188rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
}

.intro {
  margin-bottom: 22rpx;
}

.intro-copy {
  color: #564334;
  font-size: 24rpx;
  line-height: 36rpx;
}

.hero-card {
  position: relative;
  width: 100%;
  height: 270rpx;
  margin-bottom: 36rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #30201a;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.hero-image,
.hero-shade,
.hero-body {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-shade {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0.18) 44%, rgba(0, 0, 0, 0.68) 100%);
}

.hero-body {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  color: #ffffff;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.pin-chip {
  padding: 6rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
  line-height: 30rpx;
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
}

.star {
  font-size: 30rpx;
  line-height: 30rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  line-height: 48rpx;
  font-weight: 700;
}

.hero-count {
  display: flex;
  align-items: flex-end;
  margin-top: -2rpx;
}

.hero-number {
  font-size: 84rpx;
  line-height: 82rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.hero-unit {
  margin-left: 10rpx;
  padding-bottom: 8rpx;
  font-size: 30rpx;
  line-height: 38rpx;
  font-weight: 600;
}

.hero-date {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  line-height: 30rpx;
}

.date-icon {
  position: relative;
  width: 18rpx;
  height: 18rpx;
  margin-right: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 4rpx;
}

.date-icon::before {
  content: "";
  position: absolute;
  left: 3rpx;
  right: 3rpx;
  top: 5rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
}

.date-icon::after {
  content: "";
  position: absolute;
  left: 4rpx;
  top: -4rpx;
  width: 2rpx;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 7rpx 0 0 rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.section-title {
  color: #1b1b1d;
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 600;
}

.section-link {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  color: #904d00;
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 500;
}

.event-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.event-card {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 116rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e5e5e7;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.82);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  transition: transform 80ms ease;
}

.event-card-active {
  transform: scale(0.98);
}

.event-main {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1 1 auto;
}

.event-icon {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  margin-right: 22rpx;
  border-radius: 12rpx;
  background: #e4e2e4;
  color: #564334;
  font-size: 26rpx;
  font-weight: 600;
}

.event-icon-featured {
  background: #ffdcc3;
  color: #6e3900;
}

.event-symbol {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  color: currentColor;
}

.event-symbol-heart::before,
.event-symbol-heart::after {
  content: "";
  position: absolute;
  top: 7rpx;
  width: 14rpx;
  height: 20rpx;
  border: 3rpx solid currentColor;
  border-bottom: 0;
  border-radius: 14rpx 14rpx 0 0;
  background: transparent;
}

.event-symbol-heart::before {
  left: 7rpx;
  transform: rotate(-45deg);
  transform-origin: 0 100%;
}

.event-symbol-heart::after {
  right: 7rpx;
  transform: rotate(45deg);
  transform-origin: 100% 100%;
}

.event-symbol-sparkles::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 3rpx;
  width: 12rpx;
  height: 12rpx;
  border-left: 3rpx solid currentColor;
  border-top: 3rpx solid currentColor;
  transform: rotate(45deg);
}

.event-symbol-sparkles::after {
  content: "";
  position: absolute;
  right: 4rpx;
  bottom: 5rpx;
  width: 8rpx;
  height: 8rpx;
  border-left: 3rpx solid currentColor;
  border-top: 3rpx solid currentColor;
  transform: rotate(45deg);
  opacity: 0.7;
}

.event-symbol-waves::before,
.event-symbol-waves::after {
  content: "";
  position: absolute;
  left: 2rpx;
  width: 30rpx;
  height: 8rpx;
  border-top: 3rpx solid currentColor;
  border-radius: 50%;
}

.event-symbol-waves::before {
  top: 8rpx;
  box-shadow: 0 8rpx 0 -1rpx currentColor;
}

.event-symbol-waves::after {
  top: 24rpx;
}

.event-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.event-title {
  color: #1b1b1d;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 600;
}

.event-date {
  margin-top: 2rpx;
  color: #564334;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 600;
}

.event-count {
  display: flex;
  align-items: baseline;
  flex: 0 0 auto;
  min-width: 92rpx;
  margin-left: 16rpx;
  justify-content: flex-end;
}

.event-number {
  color: #564334;
  font-size: 38rpx;
  line-height: 46rpx;
  font-weight: 600;
}

.event-number-featured {
  color: #ff8c00;
}

.event-unit {
  margin-left: 6rpx;
  color: #564334;
  font-size: 20rpx;
  line-height: 28rpx;
  font-weight: 600;
}

.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 52rpx;
  padding-bottom: 88rpx;
  color: rgba(86, 67, 52, 0.38);
}

.empty-icon {
  position: relative;
  width: 38rpx;
  height: 38rpx;
  margin-bottom: 16rpx;
  border: 3rpx solid currentColor;
  border-radius: 8rpx;
  transform: rotate(-8deg);
}

.empty-line {
  position: absolute;
  left: 8rpx;
  height: 3rpx;
  background: currentColor;
  border-radius: 999rpx;
}

.empty-line-one {
  top: 9rpx;
  width: 18rpx;
}

.empty-line-two {
  top: 17rpx;
  width: 14rpx;
}

.empty-line-three {
  top: 25rpx;
  width: 20rpx;
}

.empty-text {
  font-size: 24rpx;
  line-height: 36rpx;
}

.fab {
  position: fixed;
  left: 50%;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  z-index: 18;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 292rpx;
  height: 88rpx;
  padding: 0 36rpx;
  border-radius: 999rpx;
  background: #ff8c00;
  color: #ffffff;
  box-shadow: 0 18rpx 52rpx rgba(255, 140, 0, 0.3);
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 600;
  transform: translateX(-50%);
}

.fab-active {
  transform: translateX(-50%) scale(0.96);
}

.fab-icon {
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  font-size: 22rpx;
  line-height: 24rpx;
}

.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 16;
  display: flex;
  justify-content: space-around;
  min-height: 100rpx;
  padding: 6rpx 32rpx calc(8rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(221, 193, 174, 0.45);
  border-radius: 24rpx 24rpx 0 0;
  background: rgba(255, 255, 255, 0.9);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  min-width: 120rpx;
  min-height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #5d5e60;
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 500;
}

.tab-active {
  color: #904d00;
  font-weight: 600;
}

.tab-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 2rpx;
}

.tab-home::before {
  content: "";
  position: absolute;
  left: 4rpx;
  top: 13rpx;
  width: 24rpx;
  height: 17rpx;
  background: currentColor;
  border-radius: 4rpx 4rpx 5rpx 5rpx;
}

.tab-home::after {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 3rpx;
  width: 20rpx;
  height: 20rpx;
  background: currentColor;
  transform: rotate(45deg);
  border-radius: 4rpx;
}

.tab-home-door {
  position: absolute;
  left: 14rpx;
  bottom: 3rpx;
  z-index: 1;
  width: 6rpx;
  height: 11rpx;
  background: #ffffff;
  border-radius: 3rpx 3rpx 0 0;
}

.tab-book {
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
}

.tab-book::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 5rpx;
  bottom: 5rpx;
  width: 3rpx;
  background: currentColor;
  border-radius: 999rpx;
}

.tab-user::before {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 3rpx;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.tab-user::after {
  content: "";
  position: absolute;
  left: 5rpx;
  bottom: 2rpx;
  width: 22rpx;
  height: 12rpx;
  border: 3rpx solid currentColor;
  border-radius: 18rpx 18rpx 4rpx 4rpx;
}
